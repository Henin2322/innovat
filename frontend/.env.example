# ─── DEPLOYED CONTRACT ADDRESSES ────────────────────────────────────────────
# Fill these in after running: cd contracts && npx hardhat run scripts/deploy.js --network mumbai

NEXT_PUBLIC_INNOV_TOKEN_ADDRESS=0x_FILL_AFTER_DEPLOY
NEXT_PUBLIC_CHALLENGE_REWARDS_ADDRESS=0x_FILL_AFTER_DEPLOY
NEXT_PUBLIC_NFT_CERTIFICATE_ADDRESS=0x_FILL_AFTER_DEPLOY
NEXT_PUBLIC_GOVERNANCE_ADDRESS=0x_FILL_AFTER_DEPLOY

# ─── CHAIN CONFIG ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=80001
# For local Hardhat node use: NEXT_PUBLIC_CHAIN_ID=31337

# ─── WALLETCONNECT ───────────────────────────────────────────────────────────
# Free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ─── ALCHEMY RPC ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALCHEMY_MUMBAI_URL=https://polygon-mumbai.g.alchemy.com/v2/your_key

# ─── AI CHALLENGE GENERATION ────────────────────────────────────────────────
# OpenAI API key for AI-powered challenge generation
# Get free credits at https://platform.openai.com
OPENAI_API_KEY=sk-your_openai_api_key

# ─── IPFS STORAGE ────────────────────────────────────────────────────────────
# nft.storage API key (free at https://nft.storage)
NFT_STORAGE_API_KEY=your_nft_storage_api_key
