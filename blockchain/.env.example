# Your MetaMask wallet private key (export from MetaMask → Account Details → Export Private Key)
# WARNING: Never commit this file to git
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Alchemy Mumbai RPC URL (free at https://alchemy.com)
# Create app → select Polygon Mumbai → copy HTTP URL
ALCHEMY_MUMBAI_URL=https://polygon-mumbai.g.alchemy.com/v2/your_api_key_here

# Polygonscan API key for contract verification (free at https://mumbai.polygonscan.com/apis)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
